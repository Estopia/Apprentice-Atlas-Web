{
  "name": "apprentice-atlas-web",
  "version": "0.1.0",
  "private": true,
  "license": "PolyForm-Noncommercial-1.0.0",
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=24.18.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm --parallel --filter @apprentice-atlas/site --filter @apprentice-atlas/cms dev",
    "dev:site": "pnpm --filter @apprentice-atlas/site dev",
    "dev:cms": "pnpm --filter @apprentice-atlas/cms dev",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "test:e2e": "pnpm --filter @apprentice-atlas/site test:e2e",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "24.10.4",
    "prettier": "3.8.1",
    "typescript": "6.0.3"
  }
}
